#!/bin/bash

# LandRight Pre-Push Hook
# Enforces quality gate: Playwright regression must pass before push
#
# To install: ./scripts/install-githooks.sh
# To bypass (emergency only): git push --no-verify

set -e

echo "============================================"
echo "  LandRight Pre-Push Quality Gate"
echo "============================================"
echo ""

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Navigate to frontend directory
FRONTEND_DIR="$(git rev-parse --show-toplevel)/frontend"

if [ ! -d "$FRONTEND_DIR" ]; then
    echo -e "${RED}ERROR: frontend directory not found${NC}"
    exit 1
fi

cd "$FRONTEND_DIR"

echo "Running Playwright regression tests..."
echo "Command: npm run test:smoke"
echo ""

# Run smoke tests (faster than full regression for pre-push)
# For full regression, change to: npm run test:e2e
if npm run test:smoke; then
    echo ""
    echo -e "${GREEN}✅ Smoke tests PASSED${NC}"
    echo ""
    
    # Optionally run evidence screenshots
    # Uncomment below for stricter enforcement
    # echo "Capturing evidence screenshots..."
    # npm run test:evidence
    
    echo "============================================"
    echo -e "${GREEN}  QUALITY GATE: PASSED${NC}"
    echo "  Push allowed."
    echo "============================================"
    exit 0
else
    echo ""
    echo -e "${RED}❌ QUALITY GATE FAILED${NC}"
    echo ""
    echo "============================================"
    echo -e "${RED}  PUSH BLOCKED: Playwright tests failed${NC}"
    echo "============================================"
    echo ""
    echo "To fix:"
    echo "  1. Run: cd frontend && npm run test:e2e:debug"
    echo "  2. Fix failing tests"
    echo "  3. Re-run: npm run test:e2e"
    echo "  4. Push again"
    echo ""
    echo -e "${YELLOW}To bypass (EMERGENCY ONLY):${NC}"
    echo "  git push --no-verify"
    echo ""
    exit 1
fi
